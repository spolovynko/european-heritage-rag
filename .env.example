APP_ENV=local
LOG_LEVEL=INFO

# Wellcome Collection discovery and IIIF request policy
WELLCOME_CATALOGUE_BASE_URL=https://api.wellcomecollection.org/catalogue/v2/
WELLCOME_USER_AGENT=HeritageRAG/0.1.0
WELLCOME_CONNECT_TIMEOUT_SECONDS=5
WELLCOME_READ_TIMEOUT_SECONDS=30
WELLCOME_WRITE_TIMEOUT_SECONDS=30
WELLCOME_POOL_TIMEOUT_SECONDS=5
WELLCOME_MAX_ATTEMPTS=4
WELLCOME_MAX_RETRY_WAIT_SECONDS=8

# Status and work-level resume checkpoint directory
INGESTION_STATE_DIRECTORY=var/ingestion
BRONZE_DATA_DIRECTORY=data/bronze
SILVER_DATA_DIRECTORY=data/silver
GOLD_DATA_DIRECTORY=data/gold
